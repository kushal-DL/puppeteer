# Required
GITHUB_TOKEN=ghp_your_token_here
WEBHOOK_SECRET=your_webhook_secret
GEMINI_API_KEY=your_gemini_key

# Target repo — per-request override also supported in /teams-trigger body
# Your GITHUB_TOKEN must have read/write access to all target repos.
# For cross-org usage, use a fine-grained PAT scoped to multiple repos
# or a GitHub App with multi-org installations.
REPO_OWNER=your_github_username_or_org
REPO_NAME=your_repo_name

# Optional — override defaults
# BASE_BRANCH=develop
# BOT_USERNAME=your_github_username
# BASE_WORKSPACE=/app/workspace
# DEFAULT_LLM_PROVIDER=gemini

# Ollama / OpenAI-compatible (alternative to Gemini)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY=
# OLLAMA_MODEL=llama3

# Dev features
# ENABLE_TEST_ENDPOINTS=true
