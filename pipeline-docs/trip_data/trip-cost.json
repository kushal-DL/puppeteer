{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "definitions": {
    "bookingCost": {
      "additionalProperties": false,
      "dataClassification": [],
      "description": "Single item in cost breakdown of a booking",
      "properties": {
        "code": {
          "dataClassification": [],
          "description": "Code to identify the cost type, e.g. tax code",
          "type": "string"
        },
        "costId": {
          "$ref": "shared.json#/definitions/uuid",
          "dataClassification": [],
          "description": "ID of this line item",
          "groups": [
            "external"
          ]
        },
        "inPointOfSaleCurrency": {
          "$ref": "#/definitions/cost",
          "dataClassification": [],
          "description": "Cost of this line item in point of sale currency"
        },
        "inTripCurrency": {
          "$ref": "#/definitions/cost",
          "dataClassification": [],
          "description": "Cost of this line item in trip currency"
        },
        "included": {
          "dataClassification": [],
          "description": "Flag indicating whether this cost is included in the base-amount or parent",
          "type": "boolean"
        },
        "localization": {
          "additionalProperties": false,
          "dataClassification": [],
          "properties": {
            "id": {
              "dataClassification": [],
              "description": "Text reference for translation (referring to t1/shared-localization). Format: category.userMessage.ID",
              "type": "string"
            },
            "localizedText": {
              "dataClassification": [],
              "description": "Already localized and formatted text provided by the bookingSource. Fallback (if available) in case translation via t1/shared-localization failed",
              "type": "string"
            },
            "messageParams": {
              "dataClassification": [],
              "description": "Parameters that are used in the localized text",
              "items": {
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "dataClassification": [],
                    "description": "Parameter name",
                    "type": "string"
                  },
                  "type": {
                    "dataClassification": [],
                    "description": "Type of the parameter",
                    "enum": [
                      "string",
                      "date",
                      "longdate",
                      "datetime",
                      "number"
                    ],
                    "type": "string"
                  },
                  "value": {
                    "dataClassification": [],
                    "description": "Parameter value, will be localized with user's profile if type is not 'string'",
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "type": "array"
            }
          },
          "type": "object"
        },
        "parentCostId": {
          "$ref": "shared.json#/definitions/uuid",
          "dataClassification": [],
          "description": "(Optional) ID of the parent of this line item if it should be grouped under it"
        },
        "type": {
          "dataClassification": [],
          "description": "Cost type of this line item",
          "enum": [
            "fee",
            "tax",
            "baseAmount",
            "ancillary",
            "group",
            "refund",
            "penalty",
            "section"
          ],
          "groups": [
            "external"
          ],
          "type": "string"
        }
      },
      "required": [
        "costId",
        "type"
      ],
      "type": "object"
    },
    "cost": {
      "additionalProperties": false,
      "dataClassification": [],
      "properties": {
        "amount": {
          "dataClassification": [],
          "groups": [
            "external"
          ],
          "type": "number"
        },
        "currency": {
          "$ref": "shared.json#/definitions/currency",
          "dataClassification": [],
          "groups": [
            "external"
          ]
        }
      },
      "required": [
        "amount",
        "currency"
      ],
      "type": "object"
    },
    "costBreakdown": {
      "additionalProperties": false,
      "description": "Cost breakdown for one booking (or one ticket in a booking if possible)",
      "properties": {
        "bookingCosts": {
          "dataClassification": [],
          "description": "List of all cost items",
          "groups": [
            "external"
          ],
          "items": {
            "$ref": "#/definitions/bookingCost"
          },
          "type": "array"
        },
        "bookingId": {
          "$ref": "shared.json#/definitions/uuid",
          "dataClassification": [],
          "description": "ID of the booking this breakdown relates to",
          "groups": [
            "external"
          ]
        },
        "bookingType": {
          "dataClassification": [],
          "enum": [
            "car",
            "hotel",
            "air",
            "rail",
            "misc"
          ],
          "groups": [
            "external"
          ],
          "type": "string"
        },
        "subTotalCost": {
          "additionalProperties": false,
          "dataClassification": [],
          "description": "Aggregated cost of this breakdown",
          "groups": [
            "external"
          ],
          "properties": {
            "inPointOfSaleCurrency": {
              "$ref": "#/definitions/cost",
              "dataClassification": [],
              "description": "Sub total cost in point of sale currency used by the vendor",
              "groups": [
                "external"
              ]
            },
            "inTripCurrency": {
              "$ref": "#/definitions/cost",
              "dataClassification": [],
              "description": "Sub total cost in tripCurrency",
              "groups": [
                "external"
              ]
            }
          },
          "type": "object"
        },
        "ticketReference": {
          "dataClassification": [
            "PII"
          ],
          "description": "(Optional) reference to the ticket this breakdown relates to",
          "type": "string"
        }
      },
      "required": [
        "bookingId",
        "bookingType",
        "subTotalCost"
      ],
      "type": "object"
    },
    "totalCosts": {
      "additionalProperties": false,
      "dataClassification": [],
      "description": "Aggregated costs of costBreakdowns items",
      "groups": [
        "external"
      ],
      "properties": {
        "inTripCurrency": {
          "$ref": "#/definitions/cost",
          "dataClassification": [],
          "groups": [
            "external"
          ]
        }
      },
      "type": "object"
    },
    "tripCosts": {
      "additionalProperties": false,
      "dataClassification": [],
      "description": "Contains all data related to total trip costs",
      "properties": {
        "costBreakdowns": {
          "dataClassification": [],
          "groups": [
            "external"
          ],
          "items": {
            "$ref": "#/definitions/costBreakdown"
          },
          "type": "array"
        },
        "totalCosts": {
          "$ref": "#/definitions/totalCosts",
          "dataClassification": [],
          "groups": [
            "external"
          ]
        },
        "tripCurrency": {
          "$ref": "shared.json#/definitions/currency",
          "dataClassification": [],
          "description": "Currency used at the time of trip creation, set by trip operations",
          "groups": [
            "external"
          ]
        }
      },
      "required": [
        "costBreakdowns",
        "totalCosts",
        "tripCurrency"
      ],
      "type": "object"
    }
  },
  "id": "trip-cost.json"
}