graph LR
    %% ==========================================
    %% COLOR DEFINITIONS & CONTRAST RULES
    %% ==========================================
    classDef lightGrey fill:#F5F7FA,stroke:#90A4AE,stroke-width:2px,color:#000000;
    classDef strategyBlue fill:#E1F5FE,stroke:#0288D1,stroke-width:2px,stroke-dasharray: 5 5,color:#000000;
    classDef lightOrange fill:#FFCC80,stroke:#E65100,stroke-width:2px,color:#000000;
    classDef darkOrange fill:#E65100,stroke:#BF360C,stroke-width:2px,color:#FFFFFF;
    classDef sparkBlue fill:#0288D1,stroke:#01579B,stroke-width:2px,color:#FFFFFF;
    classDef storageDark fill:#455A64,stroke:#263238,stroke-width:2px,color:#FFFFFF;
    classDef k8sGreen fill:#E8F5E9,stroke:#2E7D32,stroke-width:2px,color:#000000;

    %% ==========================================
    %% ZONE STYLING
    %% ==========================================
    style Zone1 fill:#FFFFFF,stroke:#B0BEC5,stroke-width:2px,stroke-dasharray: 5 5
    style Zone2 fill:#FAFAFA,stroke:#B0BEC5,stroke-width:2px,stroke-dasharray: 5 5
    style Zone3 fill:#F0F8FF,stroke:#0288D1,stroke-width:2px
    style Zone4 fill:#FFFFFF,stroke:#B0BEC5,stroke-width:2px,stroke-dasharray: 5 5

    style CoreEngine fill:#B3E5FC,stroke:#0288D1,stroke-width:2px
    style Strategies fill:#FFFFFF,stroke:#0288D1,stroke-width:2px,stroke-dasharray: 5 5

    subgraph Legend [Legend]
        direction TB
        L_Core["100% Shareable Core Engine"]:::sparkBlue
        L_Strat["Pipeline Specific Strategies"]:::strategyBlue
        L_K8s["Ephemeral Kubernetes Worker"]:::k8sGreen
    end

    subgraph Zone1 [Zone 1: Core Sources & Internal Cluster APIs]
        direction TB
        CDP_Storage["<b>Core Data Platform (CDP)</b><br>Raw JSONL Generator"]:::lightGrey
        CTE_APIs["<b>CTE Backend APIs (Internal)</b><br>â€¢ Subscription API<br>â€¢ App-Center (Consent)<br>â€¢ Config API<br>â€¢ Travel/Spend APIs"]:::lightGrey
    end

    subgraph Zone2 [Zone 2: Control Plane & K8s Execution]
        direction TB
        Cron["<b>AWS EventBridge</b><br>Cron Job Trigger"]:::darkOrange
        StepFunc["<b>AWS Step Functions</b><br>State Machine Orchestrator"]:::lightOrange
        InitLambda["<b>AWS Lambda (Init)</b><br>Reads Strategy & Returns Workflow"]:::lightOrange
        
        SQS["<b>AWS SQS</b><br>Cross-Boundary Task Queue<br><i>(Passes Task Tokens)</i>"]:::darkOrange
        K8sJob["<b>Kubernetes Job</b><br>Ephemeral Python Worker<br><i>(Dumb API Fetcher)</i>"]:::k8sGreen
        
        StrategyS3[("<b>Strategy S3</b><br>(CI/CD Deployed)<br>â€¢ expense_strategy.py<br>â€¢ trip_strategy.py")]:::storageDark
        IntermediaryS3[("<b>Intermediary S3</b><br>(30-day Lifecycle)<br>â€¢ UUID JSONs<br>â€¢ Pass 1 Parquet<br>â€¢ Raw API Responses")]:::storageDark
        S3Raw[("<b>Raw S3</b><br>CDP Exports")]:::storageDark
        SNS{"<b>AWS SNS</b><br>Event Bus"}:::darkOrange
    end

    subgraph Zone3 [Zone 3: PySpark Compute Engine]
        direction TB
        
        subgraph CoreEngine [Shareable: Generic Pipeline Orchestrator]
            direction TB
            GlueJob["<b>core_runner.py (AWS Glue)</b><br>Two-Pass Execution Engine"]:::sparkBlue
        end

        subgraph Strategies [Non-Shareable: Pipeline Specific Logic]
            direction TB
            ExpStrat["<b>expense_strategy.py / trip_strategy.py</b><br>â€¢ Defines Workflow Steps<br>â€¢ Defines API URLs & Auth<br>â€¢ <b>Evaluates Rules (Pass 2)</b>"]:::strategyBlue
        end
        
        GlueJob -- "Imports & Executes Spark Logic" --> ExpStrat
        InitLambda -. "Imports & Extracts Workflow" .-> ExpStrat
    end

    subgraph Zone4 [Zone 4: Downstream Egress]
        direction TB
        S3Egress[("<b>S3 Bucket</b><br>Filtered Egress")]:::storageDark
        IFM["<b>Integration File Manager (IFM)</b><br>Secure Gateway"]:::lightGrey
        AmexGBT["<b>AmexGBT</b><br>External Partner"]:::lightGrey
    end

    %% ==========================================
    %% 1. INITIALIZATION & SYNC PHASE
    %% ==========================================
    Cron -- "1 Wakes Up" --> StepFunc
    StepFunc -- "2 Invokes Init" --> InitLambda
    InitLambda -- "3 Returns Workflow Rules<br>(e.g., skip API phase)" --> StepFunc
    
    StepFunc -- "4 Drops Sync Task + Token" --> SQS
    SQS -- "5 KEDA triggers Job" --> K8sJob
    K8sJob == "6 Reads Configs" ==> StrategyS3
    K8sJob -. "7 Executes Subscription Sync" .-> CTE_APIs
    CTE_APIs -. "8 Triggers generation" .-> CDP_Storage
    CDP_Storage == "9 Drops ORC/JSONL" ==> S3Raw
    
    %% ==========================================
    %% 2. PHASE 1 (EXTRACTION)
    %% ==========================================
    S3Raw -- "10 Fires Event" --> SNS
    SNS -- "11 Wakes Step Function" --> StepFunc
    StepFunc -- "12 Native Sync" --> GlueJob
    
    S3Raw == "13 Reads Raw Data" ==> GlueJob
    GlueJob == "14 Pass 1: Extracts UUIDs & Writes Parquet" ==> IntermediaryS3
    GlueJob -- "15 Fires Completion Event" --> SNS
    SNS -- "16 Wakes Step Function" --> StepFunc

    %% ==========================================
    %% 3. ASYNC API ENRICHMENT PHASE (Conditional)
    %% ==========================================
    StepFunc -- "17 Conditional: Drops Fetch Task + Token" --> SQS
    SQS -- "18 KEDA triggers Job" --> K8sJob
    
    IntermediaryS3 == "19 Downloads UUIDs & URL Blueprints" ==> K8sJob
    StrategyS3 == "19b Reads Strategy for URLs" ==> K8sJob
    K8sJob -. "20 Fetches Data from Travel/Spend APIs" .-> CTE_APIs
    
    K8sJob == "21 Writes RAW API Responses" ==> IntermediaryS3
    K8sJob -- "22 Sends Success Callback" --> StepFunc

    %% ==========================================
    %% 4. PHASE 2 (EVALUATION & EGRESS)
    %% ==========================================
    StepFunc -- "23 Native Sync (Pass 2)" --> GlueJob
    IntermediaryS3 == "24 Reads Pass 1 Parquet & Raw API Responses" ==> GlueJob
    
    GlueJob == "25 Evaluates Rules & Writes Filtered Data" ==> S3Egress
    S3Egress == "26 Pushes Final JSONL" ==> IFM
    IFM -- "27 Delivers to" --> AmexGBT
